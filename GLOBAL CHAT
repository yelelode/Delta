local userColors = {
    Color3.fromRGB(255, 89, 89), Color3.fromRGB(89, 255, 89), Color3.fromRGB(89, 172, 255),
    Color3.fromRGB(255, 89, 255), Color3.fromRGB(255, 172, 89), Color3.fromRGB(89, 255, 255), Color3.fromRGB(172, 89, 255)
}

local function getHexColorForUser(username)
    local value = 0
    for i = 1, #username do value = value + string.byte(username, i) end
    local color = userColors[(value % #userColors) + 1]
    return string.format("#%02X%02X%02X", color.R * 255, color.G * 255, color.B * 255)
end

local function getFullUsername(partialName)
    partialName = string.lower(partialName)
    for _, p in ipairs(Players:GetPlayers()) do
        if string.sub(string.lower(p.Name), 1, #partialName) == partialName or string.sub(string.lower(p.DisplayName), 1, #partialName) == partialName then
            return p.Name
        end
    end
    for lowerName, realName in pairs(knownUsers) do
        if string.sub(lowerName, 1, #partialName) == partialName then return realName end
    end
    return nil
end

local function updateInputLayout()
    if privateTarget then
        local dName = privateTarget
        local targetPlayer = Players:FindFirstChild(privateTarget)
        if targetPlayer then dName = targetPlayer.DisplayName end
        
        PrivateBtn.Text = " [🔐 " .. dName .. "] "
        local tagWidth = TextService:GetTextSize(PrivateBtn.Text, 12, Enum.Font.GothamBold, Vector2.new(1000, 30)).X + 10
        PrivateBtn.Size = UDim2.new(0, tagWidth, 1, -6)
        PrivateBtn.Visible = true
        TextBox.Position = UDim2.new(0, 30 + tagWidth + 5, 0, 0)
        TextBox.Size = UDim2.new(1, -(30 + tagWidth + 5 + 20), 1, 0)
    else
        PrivateBtn.Visible = false
        TextBox.Position = UDim2.new(0, 30, 0, 0)
        TextBox.Size = UDim2.new(1, -50, 1, 0)
    end
end

local function setPrivateTarget(username)
    if username then
        privateTarget = getFullUsername(username) or username 
    else
        privateTarget = nil
    end
    updateInputLayout()
end

PrivateBtn.MouseButton1Click:Connect(function() setPrivateTarget(nil) end)

local function displayMessage(userName, msg, privateUserTarget, isPrivateSender)
    local displayName = userName
    local speaker = Players:FindFirstChild(userName)

    if speaker then displayName = speaker.DisplayName end
    
    -- 👑 DARK RED DADDY TAG INJECTION 
    if Admin[userName:lower()] then 
        if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
            local darkRedDaddyTag = "<font color='#8B0000'>[Daddy]</font>"
            displayName = darkRedDaddyTag .. " " .. displayName 
        else
            displayName = "[Daddy] " .. displayName 
        end
    end

    if Staff[userName:lower()] then displayName = "[Staff] " .. displayName end

    local hexColor = getHexColorForUser(userName)
    local msgColor = "#FFFF00"
    local color3Msg = Color3.fromRGB(255, 255, 0)
    
    local tagText = "💬 " .. displayName .. ":"
    if privateUserTarget then
        msgColor = "#FF9632"
        color3Msg = Color3.fromRGB(255, 150, 50)
        if isPrivateSender then
            tagText = "[🔐To " .. privateUserTarget .. "]:"
        else
            tagText = "[🔐From " .. privateUserTarget .. "]:"
        end
    end

    if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
        local formattedText = string.format("<font color='%s'><b>%s</b></font> <font color='%s'><b>%s</b></font>", hexColor, tagText, msgColor, msg)
        local channel = TextChatService.TextChannels:FindFirstChild("RBXSystem")
        if channel then channel:DisplaySystemMessage(formattedText) end
    else
        pcall(function()
            StarterGui:SetCore("ChatMakeSystemMessage", {
                Text = tagText .. " " .. msg, Color = color3Msg,
                Font = Enum.Font.SourceSansBold, FontSize = Enum.FontSize.Size18
            })
        end)
    end
end

local function displayBubble(userName, msg)
    local speaker = Players:FindFirstChild(userName)
    if not speaker or not speaker.Character then return end
    pcall(function()
        if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
            TextChatService:DisplayBubble(speaker.Character, msg)
        else
            local head = speaker.Character:FindFirstChild("Head")
            if head then ChatService:Chat(head, msg, Enum.ChatColor.White) end
        end
    end)
end

