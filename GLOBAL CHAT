-- ==========================================
-- LOGIC: DRAGGING & RESIZING & SHORTCUTS
-- ==========================================
local function setupInteractivity()
    local function makeDraggable(trigger, target)
        local dragging, dragStart, startPos
        trigger.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true; dragStart = input.Position; startPos = target.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragging then
                local delta = input.Position - dragStart
                target.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end

    makeDraggable(DragHandle, MainFrame)
    makeDraggable(EmojiTopBar, EmojiFrame)

    local resizing, resizeStart, startSize
    ResizeHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            resizing = true; resizeStart = input.Position; startSize = MainFrame.Size
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then resizing = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - resizeStart
            MainFrame.Size = UDim2.new(0, math.clamp(startSize.X.Offset + delta.X, 150, 500), 0, math.clamp(startSize.Y.Offset + delta.Y, 30, 150))
        end
    end)

    local lastExclamation = 0
    UserInputService.InputBegan:Connect(function(input, gp)
        if gp and UserInputService:GetFocusedTextBox() ~= TextBox then return end
        if input.KeyCode == Enum.KeyCode.Semicolon then
            task.delay(0.05, function() TextBox:CaptureFocus() end)
        elseif input.KeyCode == Enum.KeyCode.One and UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            lastExclamation = tick()
        elseif input.KeyCode == Enum.KeyCode.E then
            if tick() - lastExclamation < 1.5 and not UserInputService.TouchEnabled then
                EmojiFrame.Visible = not EmojiFrame.Visible
                if TextBox:IsFocused() then
                    task.delay(0.01, function() TextBox.Text = string.gsub(TextBox.Text, "!e$", "") end)
                end
            end
        end
    end
end
setupInteractivity()

