-- COMMANDS & SEND LOGIC
-- ==========================================
TextBox:GetPropertyChangedSignal("Text"):Connect(function()
    local t = TextBox.Text
    if string.match(t, "!e$") then
        TextBox.Text = string.sub(t, 1, -3)
        if not UserInputService.TouchEnabled then EmojiFrame.Visible = not EmojiFrame.Visible end
        return
    end
    local pMatch = string.match(t, "^!p%s+(%w+)%s+$")
    if pMatch then
        TextBox.Text = ""
        setPrivateTarget(pMatch)
    end
end)

local function sendPrivateMessage()
    local text = TextBox.Text
    if text == "" or not text then return end

    if processCommand(text) then
        TextBox.Text = ""
        return
    end

    local lowerText = string.lower(string.gsub(text, "%s+", ""))
    TextBox.Text = ""

    if lowerText == "!cmds" then
        local cmdStr = "Commands:\n- fly [speed], unfly\n- speed [num], jumppower [num]\n- spin, unspin, orbit [user], unorbit\n- view [user], unview, tp [user]\n- invisible, visible, noclip, clip, sit, nosit"
        displayMessage("System", cmdStr, nil, false)
        return
    elseif lowerText == "!server" then
        chatMode = "server"
        displayMessage("System", "Chat mode switched to SERVER only.", nil, false)
        return
    elseif lowerText == "!global" then
        chatMode = "global"
        displayMessage("System", "Chat mode switched to GLOBAL.", nil, false)
        return
    end

    local finalMsg = text
    if privateTarget then
        finalMsg = "( 🔐 " .. LocalPlayer.Name .. " Private " .. privateTarget .. ") " .. text
    end

    TextBox.PlaceholderText = " Sending..."
    task.spawn(function()
        local payloadObj = { user = LocalPlayer.Name, msg = finalMsg, jobId = game.JobId }
        local payload = HttpService:JSONEncode(payloadObj)
        
        local success, res = pcall(function()
            return req({
                Url = SERVER_URL .. "/send", Method = "POST",
                Headers = { ["Content-Type"] = "application/json", ["User-Agent"] = "Roblox/WinInet" },
                Body = payload
            })
        end)
        
        if success and res.StatusCode == 200 then
            TextBox.PlaceholderText = " Type message..."
        else
            TextBox.PlaceholderText = " Failed! Server asleep?"
            task.wait(2)
            TextBox.PlaceholderText = " Type message..."
        end
    end)
end

TextBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then sendPrivateMessage() end
end)

-- ==========================================
-- LOGIC: RECEIVING MESSAGES (POLLING)
-- ==========================================
local function pollMessages()
    while isPolling and task.wait(0.5) do
        local success, res = pcall(function()
            return req({
                Url = SERVER_URL .. "/messages?since=" .. tostring(lastSyncTime),
                Method = "GET", Headers = { ["User-Agent"] = "Roblox/WinInet" }
            })
        end)

        if success and res and res.StatusCode == 200 then
            local data = HttpService:JSONDecode(res.Body)
            for _, m in ipairs(data) do
                if m.time > lastSyncTime then
                    lastSyncTime = m.time
                    knownUsers[string.lower(m.user)] = m.user
                    
                    if m.hidden or m.msg == "Joined" then continue end
                    if chatMode == "server" and m.jobId ~= game.JobId then continue end
                    
                    local pSender, pTarget, pMsg = string.match(m.msg, "^%( 🔐 ([%w_]+) Private ([%w_]+)%) (.*)$")
                    
                    if pSender and pTarget then
                        if LocalPlayer.Name == pSender then
                            displayMessage(m.user, pMsg, pTarget, true)
                            displayBubble(m.user, pMsg)
                        elseif LocalPlayer.Name == pTarget then
                            displayMessage(m.user, pMsg, pSender, false)
                            displayBubble(m.user, pMsg)
                        end
                        continue 
                    end
                    
                    displayMessage(m.user, m.msg, nil, false)
                    displayBubble(m.user, m.msg)
                end
            end
        end
    end
end

