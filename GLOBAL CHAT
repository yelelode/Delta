local function processCommand(text)
    local cleanStr = text:match("^%s*[%!%;]?%s*(.-)%s*$")
    if not cleanStr or cleanStr == "" then return false end
    
    local cmd, args = cleanStr:lower():match("^(%S+)%s*(.*)$")
    if not cmd then return false end
    
    if CommandList[cmd] then
        pcall(function() CommandList[cmd](args) end)
        return true 
    end
    
    return false 
end

LocalPlayer.Chatted:Connect(function(msg)
    processCommand(msg)
end)

