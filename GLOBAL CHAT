local function getPlayer(nameStr)
    if not nameStr or nameStr == "" then return nil end
    local lowerName = nameStr:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #lowerName) == lowerName or p.DisplayName:lower():sub(1, #lowerName) == lowerName then
            return p
        end
    end
    return nil
end

local function getCharacter()
    return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function disconnectConn(name)
    if Connections[name] then
        Connections[name]:Disconnect()
        Connections[name] = nil
    end
end

