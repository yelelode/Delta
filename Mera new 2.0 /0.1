-- 🔥 HYBRID DUAL-SPEED ENGINE (V18.0) 🔥
RunService.Heartbeat:Connect(function(dt)
    if not isSystemActive then return end 

    for plr in pairs(assignedRemotes) do
        if not selectedPlayers[plr] or not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then
            assignedRemotes[plr] = nil 
        end
    end
    for plr in pairs(voidedPlayers) do
        if not selectedPlayers[plr] then
            voidedPlayers[plr] = nil
        end
    end

    local speedMultiplier = (getSpeedMs() / 20)
    animTime = animTime + (dt * speedMultiplier)
    angle = angle + (dt * speedMultiplier * 1.5)
    selfAngle = selfAngle + (dt * speedMultiplier * 2.5) 
    
    local robotSpeedMultiplier = 60 / 20 
    robotAnimTime = robotAnimTime + (dt * robotSpeedMultiplier)
    
    local allRemotes = getAvailableRemotes()
    local tCount = 0; local targetList = {}
    
    for plr, _ in pairs(selectedPlayers) do 
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then 
            table.insert(targetList, plr); tCount = tCount + 1 
        end 
    end

    if tCount > 0 and #allRemotes > 0 then
        local currentRadius = getRadius()
        local rScale = currentRadius / 15 

        for _, plr in ipairs(targetList) do
            local tRoot = plr.Character.HumanoidRootPart
            local tHum = plr.Character:FindFirstChildOfClass("Humanoid")
            if type(assignedRemotes[plr]) ~= "table" then assignedRemotes[plr] = {} end
            
            local bodyPart = plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("LowerTorso") or tRoot
            
            local targetVelocity = tRoot.AssemblyLinearVelocity
            local pingDelay = 0.05; pcall(function() pingDelay = lp:GetNetworkPing() end)
            local predictionTime = pingDelay + 0.03
            
            local bodyPos = bodyPart.Position + (targetVelocity * predictionTime)
            
            local flatLook = Vector3.new(tRoot.CFrame.LookVector.X, 0, tRoot.CFrame.LookVector.Z)
            if flatLook.Magnitude > 0.01 then flatLook = flatLook.Unit else flatLook = Vector3.new(0, 0, -1) end
            
            local dynamicBaseCFrame = CFrame.lookAt(bodyPos, bodyPos + flatLook)
            
            local isProne = (tHum and (tHum:GetState() == Enum.HumanoidStateType.Physics or tHum.Sit))
            local yOffset = isProne and -1.5 or -3.8
            local tiltAngle = isProne and math.rad(-90) or 0

            local centerGroundPos = bodyPos + Vector3.new(0, yOffset, 0)
            
            local maxBaseDist = math.max(2.5, 4.0 * rScale) 
            local touchDist = 1.0 
            
            local bangCycle = math.abs(math.sin(animTime * 6))
            local snapPower = math.pow(bangCycle, 2.5) 
            local smoothDist = maxBaseDist - ((maxBaseDist - touchDist) * snapPower)
            
            local robotBangCycle = math.abs(math.sin(robotAnimTime * 6))
            local robotSnapPower = math.pow(robotBangCycle, 2.5)
            local robotSmoothDist = maxBaseDist - ((maxBaseDist - touchDist) * robotSnapPower)

            if activeModes["HeadBang"] then
                local slots = {"h_front", "h_back"}
                for _, slot in ipairs(slots) do if not assignedRemotes[plr][slot] or not assignedRemotes[plr][slot].Parent then for _, r in ipairs(allRemotes) do if not isRemoteAssigned(r) then assignedRemotes[plr][slot] = r; break end end end end
                
                local actualHead = plr.Character:FindFirstChild("Head") or tRoot
                local headPos = actualHead.Position + (targetVelocity * predictionTime)
                local headLockCFrame = CFrame.lookAt(headPos, headPos + flatLook)
                
                local headY = isProne and -0.8 or -2.4 
                local headDist = 1.0 + (1.5 * rScale) - (((1.5 * rScale)) * snapPower)
                
                if assignedRemotes[plr].h_front then task.spawn(function() pcall(function() assignedRemotes[plr].h_front:InvokeServer(headLockCFrame * CFrame.new(0, headY, -headDist)) end) end) end
                if assignedRemotes[plr].h_back then task.spawn(function() pcall(function() assignedRemotes[plr].h_back:InvokeServer(headLockCFrame * CFrame.new(0, headY, headDist) * CFrame.Angles(0, math.rad(180), 0)) end) end) end
            end

            if activeModes["Robot"] then
                local slots = {"back", "front", "left", "right"}
                for _, slot in ipairs(slots) do if not assignedRemotes[plr][slot] or not assignedRemotes[plr][slot].Parent then for _, r in ipairs(allRemotes) do if not isRemoteAssigned(r) then assignedRemotes[plr][slot] = r; break end end end end
                
                local fPos = centerGroundPos + (dynamicBaseCFrame.LookVector * robotSmoothDist)
                local bPos = centerGroundPos - (dynamicBaseCFrame.LookVector * robotSmoothDist)
                local lPos = centerGroundPos - (dynamicBaseCFrame.RightVector * robotSmoothDist)
                local rPos = centerGroundPos + (dynamicBaseCFrame.RightVector * robotSmoothDist)
                
                if assignedRemotes[plr].front then task.spawn(function() pcall(function() assignedRemotes[plr].front:InvokeServer(CFrame.lookAt(fPos, centerGroundPos) * CFrame.Angles(tiltAngle, math.rad(180), 0)) end) end) end
                if assignedRemotes[plr].back then task.spawn(function() pcall(function() assignedRemotes[plr].back:InvokeServer(CFrame.lookAt(bPos, centerGroundPos) * CFrame.Angles(tiltAngle, math.rad(180), 0)) end) end) end
                if assignedRemotes[plr].left then task.spawn(function() pcall(function() assignedRemotes[plr].left:InvokeServer(CFrame.lookAt(lPos, centerGroundPos) * CFrame.Angles(tiltAngle, math.rad(180), 0)) end) end) end
                if assignedRemotes[plr].right then task.spawn(function() pcall(function() assignedRemotes[plr].right:InvokeServer(CFrame.lookAt(rPos, centerGroundPos) * CFrame.Angles(tiltAngle, math.rad(180), 0)) end) end) end
            end

            if activeModes["MultiRobot"] then
                local slots = {"m_back", "m_front"}
                for _, slot in ipairs(slots) do if not assignedRemotes[plr][slot] or not assignedRemotes[plr][slot].Parent then for _, r in ipairs(allRemotes) do if not isRemoteAssigned(r) then assignedRemotes[plr][slot] = r; break end end end end
                
                local fPos = centerGroundPos + (dynamicBaseCFrame.LookVector * smoothDist)
                local bPos = centerGroundPos - (dynamicBaseCFrame.LookVector * smoothDist)
                
                if assignedRemotes[plr].m_front then task.spawn(function() pcall(function() assignedRemotes[plr].m_front:InvokeServer(CFrame.lookAt(fPos, centerGroundPos) * CFrame.Angles(tiltAngle, math.rad(180), 0)) end) end) end
                if assignedRemotes[plr].m_back then task.spawn(function() pcall(function() assignedRemotes[plr].m_back:InvokeServer(CFrame.lookAt(bPos, centerGroundPos) * CFrame.Angles(tiltAngle, math.rad(180), 0)) end) end) end
            end

            if activeModes["Chair"] then
                if voidedPlayers[plr] and not tHum.Sit then voidedPlayers[plr] = nil end
                if not voidedPlayers[plr] then
                    if not assignedRemotes[plr].chair or not assignedRemotes[plr].chair.Parent then 
                        for _, r in ipairs(allRemotes) do 
                            if not isRemoteAssigned(r) then assignedRemotes[plr].chair = r; break end 
                        end 
                    end
                    if assignedRemotes[plr].chair then
                        if tHum.Sit then 
                            pcall(function() assignedRemotes[plr].chair:InvokeServer(CFrame.new(0, -5000, 0)) end)
                            voidedPlayers[plr] = true
                            assignedRemotes[plr].chair = nil
                        else
                            local jX = math.random(-15, 15) / 10
                            local jY = math.random(-30, 10) / 10 
                            local jZ = math.random(-15, 15) / 10
                            pcall(function() assignedRemotes[plr].chair:InvokeServer(tRoot.CFrame * CFrame.new(jX, jY, jZ)) end)
                        end
                    end
                end
            end
        end

        local freeRemotes = {}
        for _, r in ipairs(allRemotes) do if not isRemoteAssigned(r) then table.insert(freeRemotes, r) end end

        if #freeRemotes > 0 then
            if activeModes["Ring"] then
                for i, remote in ipairs(freeRemotes) do
                    local targetIdx = ((i - 1) % tCount) + 1; local plr = targetList[targetIdx]
                    
                    local tRoot = plr.Character.HumanoidRootPart
                    local bodyPart = plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("LowerTorso") or tRoot
                    
                    local targetVelocity = tRoot.AssemblyLinearVelocity
                    local pingDelay = 0.05; pcall(function() pingDelay = lp:GetNetworkPing() end)
                    local predictionTime = pingDelay + 0.03
                    local bodyPos = bodyPart.Position + (targetVelocity * predictionTime)
                    
                    local ringCenterPos = bodyPos + Vector3.new(0, -3.8, 0)
                    
                    local propsForThisTarget = 0; local myLocalIdx = 0
                    for j = 1, #freeRemotes do if (((j - 1) % tCount) + 1) == targetIdx then if j < i then myLocalIdx = myLocalIdx + 1 end; propsForThisTarget = propsForThisTarget + 1 end end
                    if propsForThisTarget > 0 then
                        local angleRad = (math.pi * 2 / propsForThisTarget) * myLocalIdx
                        
                        local rBaseDist = math.max(3.5, 4.5 * rScale) 
                        local rSnap = math.pow(math.abs(math.sin(animTime * 6)), 2.5)
                        local rSmooth = rBaseDist - ((rBaseDist - 1.5) * rSnap)
                        
                        local propPos = ringCenterPos + Vector3.new(math.sin(angleRad) * rSmooth, 0, math.cos(angleRad) * rSmooth)
                        
                        local finalCFrame = CFrame.lookAt(propPos, ringCenterPos) * CFrame.Angles(0, math.rad(180), 0)
                        task.spawn(function() pcall(function() remote:InvokeServer(finalCFrame) end) end)
                    end
                end
            end
            
            if activeModes["Orbit"] then
                for idx, remote in ipairs(freeRemotes) do
                    local targetIdx = ((idx - 1) % tCount) + 1; local plr = targetList[targetIdx]
                    
                    local tRoot = plr.Character.HumanoidRootPart
                    local bodyPart = plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("LowerTorso") or tRoot
                    
                    local targetVelocity = tRoot.AssemblyLinearVelocity
                    local pingDelay = 0.05; pcall(function() pingDelay = lp:GetNetworkPing() end)
                    local predictionTime = pingDelay + 0.03
                    local bodyPos = bodyPart.Position + (targetVelocity * predictionTime)
                    
                    local dynamicOrbitBase = CFrame.new(bodyPos)
                    
                    local propsForThisTarget = math.ceil(#freeRemotes / tCount); local localIdx = idx % propsForThisTarget
                    local x, y, z = 0, 0, 0; local radRatio = (localIdx / propsForThisTarget) * math.pi * 2; local localTime = angle
                    
                    if activeGeometry == "Spin" then x = math.cos(radRatio + localTime) * currentRadius; z = math.sin(radRatio + localTime) * currentRadius
                    elseif activeGeometry == "Reverse Spin" then x = math.cos(radRatio - localTime) * currentRadius; z = math.sin(radRatio - localTime) * currentRadius
                    elseif activeGeometry == "Bobbing Orbit" then x = math.cos(radRatio + localTime) * currentRadius; z = math.sin(radRatio + localTime) * currentRadius; y = math.sin((localTime * 2) + radRatio) * (currentRadius / 1.5)
                    else x = math.cos(radRatio + localTime) * currentRadius; z = math.sin(radRatio + localTime) * currentRadius end
                    
                    local calcCFrame = dynamicOrbitBase * CFrame.new(Vector3.new(x, y, z)) * CFrame.Angles(selfAngle, selfAngle, selfAngle)
                    task.spawn(function() pcall(function() remote:InvokeServer(calcCFrame) end) end)
                end
            end
        end
    end
end)

