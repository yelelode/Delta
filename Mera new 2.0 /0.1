local function createSlider(name, min, max, defaultVal, suffix)
    local container = Instance.new("Frame", mainList); container.Size = UDim2.new(1, 0, 0, 46); container.BackgroundTransparency = 1; container.LayoutOrder = getOrder(); container.ZIndex = 7
    
    local titleLabel = Instance.new("TextLabel", container); titleLabel.Size = UDim2.new(0.6, 0, 0, 14); titleLabel.Position = UDim2.new(0, 6, 0, 0); titleLabel.BackgroundTransparency = 1; titleLabel.Text = name; titleLabel.TextColor3 = Colors.SubText; titleLabel.Font = Enum.Font.GothamBold; titleLabel.TextSize = 10; titleLabel.TextXAlignment = Enum.TextXAlignment.Left; titleLabel.ZIndex = 8
    crispText(titleLabel)

    local valBadge = Instance.new("Frame", container); valBadge.Size = UDim2.new(0, 48, 0, 16); valBadge.AnchorPoint = Vector2.new(1, 0); valBadge.Position = UDim2.new(1, -6, 0, -2); valBadge.BackgroundColor3 = Colors.Primary; valBadge.BackgroundTransparency = 0.85; valBadge.ZIndex = 8; Instance.new("UICorner", valBadge).CornerRadius = UDim.new(0, 4)
    local valStroke = Instance.new("UIStroke", valBadge); valStroke.Color = Colors.Primary; valStroke.Transparency = 0.5; valStroke.Thickness = 1
    local valLabel = Instance.new("TextLabel", valBadge); valLabel.Size = UDim2.new(1, 0, 1, 0); valLabel.BackgroundTransparency = 1; valLabel.Text = defaultVal .. (suffix or ""); valLabel.TextColor3 = Colors.Primary; valLabel.Font = Enum.Font.GothamBold; valLabel.TextSize = 10; valLabel.ZIndex = 9
    crispText(valLabel)

    local bg = Instance.new("TextButton", container); bg.Size = UDim2.new(1, -20, 0, 4); bg.Position = UDim2.new(0, 10, 0, 26); bg.BackgroundColor3 = Colors.SurfaceHover; bg.Text = ""; bg.AutoButtonColor = false; bg.ZIndex = 8; Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)
    local fill = Instance.new("Frame", bg); fill.Size = UDim2.new((defaultVal - min) / (max - min), 0, 1, 0); fill.BackgroundColor3 = Color3.new(1,1,1); fill.ZIndex = 9; Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    local fillGrad = Instance.new("UIGradient", fill); fillGrad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Colors.PrimaryDark), ColorSequenceKeypoint.new(1, Colors.Primary)})
    
    local knob = Instance.new("Frame", fill); knob.Size = UDim2.new(0, 14, 0, 14); knob.AnchorPoint = Vector2.new(0.5, 0.5); knob.Position = UDim2.new(1, 0, 0.5, 0); knob.BackgroundColor3 = Colors.Text; knob.ZIndex = 11; Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)
    local knobDot = Instance.new("Frame", knob); knobDot.Size = UDim2.new(0, 6, 0, 6); knobDot.AnchorPoint = Vector2.new(0.5, 0.5); knobDot.Position = UDim2.fromScale(0.5, 0.5); knobDot.BackgroundColor3 = Colors.Primary; knobDot.BorderSizePixel = 0; knobDot.ZIndex = 12; Instance.new("UICorner", knobDot).CornerRadius = UDim.new(1,0)
    local knobStroke = Instance.new("UIStroke", knob); knobStroke.Color = Colors.Primary; knobStroke.Transparency = 0.8; knobStroke.Thickness = 2

    local value = defaultVal; local dragging = false
    local function update(input) 
        local pos = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        TweenService:Create(fill, TweenInfo.new(0.1, Enum.EasingStyle.Sine), {Size = UDim2.new(pos, 0, 1, 0)}):Play()
        value = math.floor(min + (pos * (max - min))); valLabel.Text = value .. (suffix or "")
    end
    bg.InputBegan:Connect(function(input) 
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
            dragging = true; 
            TweenService:Create(knob, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 18, 0, 18)}):Play(); 
            TweenService:Create(knobDot, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Size = UDim2.new(0, 8, 0, 8)}):Play(); 
            TweenService:Create(knobStroke, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Transparency = 0.2, Thickness = 4}):Play(); 
            TweenService:Create(valBadge, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {BackgroundTransparency = 0.5}):Play(); 
            TweenService:Create(valStroke, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Transparency = 0}):Play(); 
            update(input) 
        end 
    end)
    bg.InputEnded:Connect(function(input) 
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
            dragging = false; 
            TweenService:Create(knob, TweenInfo.new(0.5, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {Size = UDim2.new(0, 14, 0, 14)}):Play(); 
            TweenService:Create(knobDot, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {Size = UDim2.new(0, 6, 0, 6)}):Play(); 
            TweenService:Create(knobStroke, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {Transparency = 0.8, Thickness = 2}):Play(); 
            TweenService:Create(valBadge, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {BackgroundTransparency = 0.85}):Play(); 
            TweenService:Create(valStroke, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {Transparency = 0.5}):Play()
        end 
    end)
    UserInputService.InputChanged:Connect(function(input) if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then update(input) end end)
    return function() return value end
end

