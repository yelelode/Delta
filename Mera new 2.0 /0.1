local function getActivePropData()
    local needsChair = activeModes["Chair"]
    local needsRobot = activeModes["Robot"] or activeModes["MultiRobot"] or activeModes["Orbit"] or activeModes["Ring"] or activeModes["HeadBang"]
    
    if needsChair and not needsRobot then
        return "FurnitureBleachers", "Furniture"
    else
        return "ScreensRobotBig", "Screens"
    end
end

local mouse = lp:GetMouse()
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end 
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if not isSystemActive then return end
        local char = lp.Character
        local tool = char and char:FindFirstChildOfClass("Tool")
        if tool and (string.find(string.lower(tool.Name), "prop") or string.find(string.lower(tool.Name), "box")) then
            task.delay(0.05, function()
                if tick() - lastGameSpawnTime > 0.5 then
                    local propName, propCategory = getActivePropData()
                    spawnProp(propName, propCategory)
                end
            end)
        end
    end
end)

