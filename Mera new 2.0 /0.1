    if isRainbowEnabled then 
        local speedMultiplier = (getSpeedMs() / 20)
        hue = (hue + (0.5 * speedMultiplier * dt)) % 1
        local color = Color3.fromHSV(hue, 1, 1) 
        
        for _, prop in ipairs(propsCache) do 
            if prop and prop.Parent then
                for _, desc in ipairs(prop:GetDescendants()) do 
                    if desc:IsA("BasePart") then 
                        pcall(function()
                            desc.Color = color 
                            if desc.Material ~= Enum.Material.Neon then desc.Material = Enum.Material.Neon end
                        end)
                    end
                    if desc:IsA("SpecialMesh") then
                        pcall(function() desc.TextureId = ""; desc.VertexColor = Vector3.new(color.R, color.G, color.B) end)
                    end
                end 
            end
        end
    end
end)

