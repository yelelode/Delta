local function applyGlowAndHover(obj, defaultColor, hoverColor, glowColor, customClickColor)
    local uiStroke = Instance.new("UIStroke", obj)
    uiStroke.Thickness = 1.5; uiStroke.Color = glowColor or hoverColor; uiStroke.Transparency = 1
    
    local btnScale = obj:FindFirstChildOfClass("UIScale") or Instance.new("UIScale", obj)
    btnScale.Scale = 1
    local activeClickColor = customClickColor or Colors.ClickAccent

    obj.MouseEnter:Connect(function()
        TweenService:Create(obj, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundColor3 = hoverColor}):Play()
        TweenService:Create(uiStroke, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Transparency = 0}):Play()
        TweenService:Create(btnScale, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1.03}):Play()
    end)
    
    obj.MouseLeave:Connect(function()
        TweenService:Create(obj, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundColor3 = defaultColor}):Play()
        TweenService:Create(uiStroke, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Transparency = 1}):Play()
        TweenService:Create(btnScale, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Scale = 1}):Play()
    end)

    obj.MouseButton1Down:Connect(function()
        TweenService:Create(obj, TweenInfo.new(0.1, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {BackgroundColor3 = activeClickColor}):Play()
        TweenService:Create(uiStroke, TweenInfo.new(0.1, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {Color = activeClickColor, Transparency = 0}):Play()
        TweenService:Create(btnScale, TweenInfo.new(0.1, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 0.94}):Play()
    end)
    
    obj.MouseButton1Up:Connect(function()
        TweenService:Create(obj, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundColor3 = hoverColor}):Play()
        TweenService:Create(uiStroke, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Color = glowColor or hoverColor}):Play()
        TweenService:Create(btnScale, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1.03}):Play()
    end)
end

