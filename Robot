local function calculateOffset(idx, totalProps, radius, localTime)
    local x, y, z = 0, 0, 0; local radRatio = (idx / totalProps) * math.pi * 2
    if activeGeometry == "Spin" then x = math.cos(radRatio + localTime) * radius; z = math.sin(radRatio + localTime) * radius
    elseif activeGeometry == "Reverse Spin" then x = math.cos(radRatio - localTime) * radius; z = math.sin(radRatio - localTime) * radius
    elseif activeGeometry == "Bobbing Orbit" then x = math.cos(radRatio + localTime) * radius; z = math.sin(radRatio + localTime) * radius; y = math.sin((localTime * 2) + radRatio) * (radius / 1.5)
    elseif activeGeometry == "Vertical Halo" then z = (radius / 1.5) + 2; x = math.cos(radRatio + localTime) * radius; y = math.sin(radRatio + localTime) * radius
    elseif activeGeometry == "Atom" then local ring = idx % 3; local ringAngle = radRatio + localTime; if ring == 0 then x = math.cos(ringAngle) * radius; z = math.sin(ringAngle) * radius elseif ring == 1 then x = math.cos(ringAngle) * radius; y = math.sin(ringAngle) * radius else y = math.cos(ringAngle) * radius; z = math.sin(ringAngle) * radius end
    elseif activeGeometry == "Galaxy Spiral" then local r = (idx / totalProps) * radius + (radius * 0.2); local spiralAngle = (idx / totalProps) * math.pi * 2 + localTime; if (idx % 2) == 1 then spiralAngle = spiralAngle + math.pi end; x = math.cos(spiralAngle) * r; z = math.sin(spiralAngle) * r
    elseif activeGeometry == "Crown" then y = (radius / 1.5) + 3; x = math.cos(radRatio + localTime) * radius; z = math.sin(radRatio + localTime) * radius; y = y + math.sin(radRatio) * (math.sin(localTime) * (radius * 0.2))
    elseif activeGeometry == "DNA" then local offsetPhase = (idx % 2 == 0) and 0 or math.pi; x = math.cos((idx * 0.5) + localTime + offsetPhase) * radius; y = (idx - (totalProps/2)) * (radius/10); z = math.sin((idx * 0.5) + localTime + offsetPhase) * radius
    elseif activeGeometry == "Wings" then local iOff = math.ceil(idx / 2); x = ((idx % 2 == 0) and 1 or -1) * (iOff * (radius/5)); y = iOff * (radius/10); z = iOff * (radius/5)
    elseif activeGeometry == "Discipline Army" then local cols = math.ceil(math.sqrt(totalProps)); x = ((idx - 1) % cols - cols/2) * (radius/2); z = (math.floor((idx - 1) / cols) - cols/2) * (radius/2)
    elseif activeGeometry == "Flower" then local r = radius * math.cos(5 * radRatio + localTime); x = r * math.cos(radRatio); z = r * math.sin(radRatio)
    elseif activeGeometry == "Domain Expansion" then local phi = math.acos(1 - 2 * (idx / totalProps)); local theta = math.sqrt(totalProps * math.pi) * phi + localTime; x = radius * math.sin(phi) * math.cos(theta); y = radius * math.sin(phi) * math.sin(theta); z = radius * math.cos(phi)
    elseif activeGeometry == "Snake Body" then x = math.sin(localTime - (idx * 0.2)) * radius; z = (idx * (radius/5))
    else x = math.cos(radRatio + localTime) * radius; z = math.sin(radRatio + localTime) * radius end
    return Vector3.new(x, y, z)
end

